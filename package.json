{
  "name": "astraoffer-assistant",
  "version": "1.0.1",
  "description": "AstraOffer Assistant — Real-time AI meeting co-pilot",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "AstraOffer",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "openai": "^4.100.0",
    "pdf2json": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.0.0",
    "electron": "^29.4.6",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.astraoffer.assistant",
    "productName": "AstraOffer Assistant",
    "artifactName": "AstraOffer-Assistant-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["arm64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
